generator client {
  provider = "prisma-client-js"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////
// ENUM
//////////////////////////

enum Role {
  LURAH
  PERANGKAT_DESA
  ADMIN
}

enum StatusMasukan {
  MENUNGGU
  DIVERIFIKASI
  DITOLAK
}

enum StatusRekomendasi {
  DRAFT
  DIAJUKAN
  DISETUJUI
  DITOLAK
}

//////////////////////////
// MASTER DOMAIN ISU
//////////////////////////

model DomainIsu {
  id        String  @id @default(cuid())
  code      String  @unique @db.VarChar(50) // INFRASTRUKTUR, KESEHATAN, dll
  nama      String  @db.VarChar(100)
  deskripsi String?

  masukan       MasukanWarga[]
  dataMaster    DataMaster[]
  rekomendasi   Rekomendasi[]
  kegiatanRapat KegiatanRapat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////
// USER
//////////////////////////

model User {
  id       String  @id @default(cuid())
  name     String  @db.VarChar(255)
  email    String  @unique
  jabatan  String? @db.VarChar(100)
  role     Role    @default(PERANGKAT_DESA)
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  masukanVerifikasi   MasukanWarga[]  @relation("VerifikatorMasukan")
  rekomendasiDiproses Rekomendasi[]   @relation("PemrosesRekomendasi")
  emailVerified       Boolean         @default(false)
  image               String?
  sessions            Session[]
  accounts            Account[]
  kegiatanRapat       KegiatanRapat[]
  dataMaster          DataMaster[]

  @@map("user")
}

//////////////////////////
// MASUKAN WARGA
//////////////////////////

model MasukanWarga {
  id           String  @id @default(cuid())
  namaPengirim String? @db.VarChar(255)
  nomorHp      String? @db.VarChar(15)
  judul        String  @db.VarChar(255)
  deskripsi    String
  lokasiRt     String  @db.VarChar(3)
  lokasiRw     String  @db.VarChar(3)

  domainIsuId String
  domainIsu   DomainIsu @relation(fields: [domainIsuId], references: [id])

  status          StatusMasukan @default(MENUNGGU)
  alasanPenolakan String?       @db.Text

  diverifikasiOlehId String?
  diverifikasiOleh   User?   @relation("VerifikatorMasukan", fields: [diverifikasiOlehId], references: [id])

  rekomendasiLinks RekomendasiMasukan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////
// DATA MASTER (KNOWLEDGE BASE)
//////////////////////////

model DataMaster {
  id String @id @default(cuid())

  domainIsuId String
  domainIsu   DomainIsu @relation(fields: [domainIsuId], references: [id])

  namaAtribut String @db.VarChar(100)
  nilai       String @db.VarChar(255)
  jumlah      Int?

  lokasiRt Int?
  lokasiRw Int?

  sumberData     String? @db.VarChar(100) // opsional: BPS, Survey Internal, dll
  diprosesOlehId String?
  diprosesOleh   User?   @relation(fields: [diprosesOlehId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([domainIsuId, namaAtribut, lokasiRt, lokasiRw])
}

//////////////////////////
// REKOMENDASI (OUTPUT AI)
//////////////////////////

model Rekomendasi {
  id String @id @default(cuid())

  kegiatanRapatId String
  kegiatanRapat   KegiatanRapat @relation(fields: [kegiatanRapatId], references: [id])

  domainIsuId String
  domainIsu   DomainIsu @relation(fields: [domainIsuId], references: [id])

  judul     String @db.VarChar(255)
  ringkasan String @db.VarChar(500)
  deskripsi String

  skorPrioritas Float
  status        StatusRekomendasi @default(DRAFT)

  laporanLengkap Json // output reasoning Gemini (structured)

  diprosesOlehId String?
  diprosesOleh   User?   @relation("PemrosesRekomendasi", fields: [diprosesOlehId], references: [id])

  masukanLinks RekomendasiMasukan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////
// MANY-TO-MANY
//////////////////////////

model RekomendasiMasukan {
  rekomendasiId String
  masukanId     String

  rekomendasi Rekomendasi  @relation(fields: [rekomendasiId], references: [id])
  masukan     MasukanWarga @relation(fields: [masukanId], references: [id])

  @@id([rekomendasiId, masukanId])
}

//////////////////////////
// BETTERAUTH
//////////////////////////

model Session {
  id          String   @id
  expiresAt   DateTime
  token       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ipAddress   String?
  userAgent   String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String?
  phoneNumber String?
  jabatan     String?
  isActive    Boolean?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model KegiatanRapat {
  id String @id @default(cuid())

  judul     String   @db.VarChar(255)
  deskripsi String   @db.Text
  tanggal   DateTime
  lokasi    String?  @db.VarChar(100)

  // optional scope
  domainIsuId String?
  domainIsu   DomainIsu? @relation(fields: [domainIsuId], references: [id])

  dibuatOlehId String
  dibuatOleh   User   @relation(fields: [dibuatOlehId], references: [id])

  // AI execution metadata
  aiModel       String? // gemini-1.5-pro, dll
  aiPromptHash  String? // untuk audit
  aiProcessedAt DateTime?

  rekomendasi Rekomendasi[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
