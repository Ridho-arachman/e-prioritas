
generator client {
  provider = "prisma-client-js"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////
// ENUM
//////////////////////////

enum Role {
  LURAH
  PERANGKAT_DESA
  ADMIN
}

enum StatusMasukan {
  MENUNGGU
  DIVERIFIKASI
  DITOLAK
  DIPROSES
  DISELESAIKAN
}

enum StatusRekomendasi {
  DRAFT
  DIAJUKAN
  DISETUJUI
  DITOLAK
}

enum NilaiKritikalitas {
  KRITIS
  TINGGI
  SEDANG
  RENDAH
}

enum ModeRekomendasi {
  FUSI_DATA
  DATA_MASTER_SAJA
}

//////////////////////////
// MASTER DOMAIN ISU
//////////////////////////

model DomainIsu {
  id        String  @id @default(cuid())
  code      String  @unique @db.VarChar(50)
  nama      String  @db.VarChar(100)
  deskripsi String?

  masukan       MasukanWarga[]
  dataMaster    DataMaster[]
  kegiatanRapat KegiatanRapat[]
  programKelurahan ProgramKelurahan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("domain_isu")
}

//////////////////////////
// USER
//////////////////////////

model User {
  id       String  @id @default(cuid())
  name     String  @db.VarChar(255)
  email    String  @unique
  jabatan  String? @db.VarChar(100)
  role     Role    @default(PERANGKAT_DESA)
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relasi
  masukanVerifikasi     MasukanWarga[]  @relation("VerifikatorMasukan")
  kegiatanRapatDiproses KegiatanRapat[] @relation("PemrosesRekomendasi")
  kegiatanRapatDibuat   KegiatanRapat[] @relation("PembuatKegiatan")
  dataMasterDibuat      DataMaster[]    @relation("PembuatDataMaster")

  // BetterAuth fields
  emailVerified Boolean   @default(false)
  image         String?
  sessions      Session[]
  accounts      Account[]

  @@map("user")
}

//////////////////////////
// MASUKAN WARGA
//////////////////////////

model MasukanWarga {
  id           String  @id @default(cuid())
  namaPengirim String? @db.VarChar(255)
  nomorHp      String? @db.VarChar(255)  /// @encrypted
  judul        String  @db.VarChar(255)
  deskripsi    String  @db.Text
  lokasiRt     String  @db.VarChar(3)
  lokasiRw     String  @db.VarChar(3)

  domainIsuId String
  domainIsu   DomainIsu @relation(fields: [domainIsuId], references: [id])

  status          StatusMasukan @default(MENUNGGU)
  alasanPenolakan String?       @db.Text

  diverifikasiOlehId String?
  diverifikasiOleh   User?   @relation("VerifikatorMasukan", fields: [diverifikasiOlehId], references: [id])

  // Relasi ke junction table (MENGGABUNGKAN RekomendasiMasukan dan ItemPrioritasMasukan)
  relasiRapat KegiatanRapatMasukan[]
  gambarMasukan GambarMasukan[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([domainIsuId])
  @@map("masukan_warga")
}

model GambarMasukan {
  id        String   @id @default(cuid())
  url       String   @db.Text // URL Cloudinary
  publicId  String   @db.Text // public_id untuk delete nanti
  masukanId String
  masukan   MasukanWarga @relation(fields: [masukanId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gambar_masukan")
}

//////////////////////////
// DATA MASTER
//////////////////////////

model DataMaster {
  id String @id @default(cuid())

  domainIsuId String
  domainIsu   DomainIsu @relation(fields: [domainIsuId], references: [id])

  namaAtribut  String            @db.VarChar(100)
  kritikalitas NilaiKritikalitas
  jumlah       Int?

  isActive  Boolean @default(true)
  tahunData Int?

  diprosesOlehId String?
  diprosesOleh   User?   @relation("PembuatDataMaster", fields: [diprosesOlehId], references: [id])

  dataMasterRelasi KegiatanRapatDataMaster[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([domainIsuId, namaAtribut])
  @@index([isActive])
  @@map("data_master")
}

//////////////////////////
// KEGIATAN RAPAT + REKOMENDASI
//////////////////////////

model KegiatanRapat {
  id String @id @default(cuid())

  // Info rapat
  judul     String   @db.VarChar(255)
  deskripsi String   @db.Text
  tanggal   DateTime
  lokasi    String?  @db.VarChar(100)

  domainIsuId String
  domainIsu   DomainIsu @relation(fields: [domainIsuId], references: [id])

  dibuatOlehId String
  dibuatOleh   User   @relation("PembuatKegiatan", fields: [dibuatOlehId], references: [id])

  // REKOMENDASI
  mode              ModeRekomendasi
  judulLaporan      String            @db.VarChar(255)
  rekomendasiItems  Json
  fingerprint       String            @unique
  statusRekomendasi StatusRekomendasi @default(DRAFT)
  // AI Metadata
  aiModel           String?
  aiProcessedAt     DateTime?

  // Relasi - untuk yang diproses (approval)
  diprosesOlehId String?
  diprosesOleh   User?   @relation("PemrosesRekomendasi", fields: [diprosesOlehId], references: [id])

  // Relasi ke junction table (MENGGABUNGKAN)
  masukanRelasi    KegiatanRapatMasukan[]
  dataMasterRelasi KegiatanRapatDataMaster[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([statusRekomendasi])
  @@index([fingerprint])
  @@index([domainIsuId])
  @@map("kegiatan_rapat")
}

//////////////////////////
// JUNCTION TABLE GABUNGAN (MENGGANTIKAN 2 JUNCTION SEBELUMNYA)
//////////////////////////

model KegiatanRapatMasukan {
  id              String @id @default(cuid())
  kegiatanRapatId String
  masukanId       String

  // Relasi
  kegiatanRapat KegiatanRapat @relation(fields: [kegiatanRapatId], references: [id], onDelete: Cascade)
  masukan       MasukanWarga  @relation(fields: [masukanId], references: [id])

  createdAt DateTime @default(now())

  @@unique([kegiatanRapatId, masukanId])
  @@index([kegiatanRapatId])
  @@index([masukanId])
  @@map("kegiatan_rapat_masukan")
}

model KegiatanRapatDataMaster {
  id              String @id @default(cuid())
  kegiatanRapatId String
  dataMasterId    String

  // Relasi
  kegiatanRapat KegiatanRapat @relation(fields: [kegiatanRapatId], references: [id], onDelete: Cascade)
  dataMaster    DataMaster    @relation(fields: [dataMasterId], references: [id])

  createdAt DateTime @default(now())

  @@unique([kegiatanRapatId, dataMasterId])
  @@index([kegiatanRapatId])
  @@index([dataMasterId])
  @@map("kegiatan_rapat_data_master")
}

//////////////////////////
// BETTERAUTH
//////////////////////////

model Session {
  id          String   @id
  expiresAt   DateTime
  token       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ipAddress   String?
  userAgent   String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String?
  phoneNumber String?
  jabatan     String?
  isActive    Boolean?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model RateLimit {
  id          String @id
  key         String
  count       Int
  lastRequest BigInt

  @@unique([key])
  @@map("rateLimit")
}

enum StatusProgram {
  BERJALAN
  SELESAI
  DITUNDA
}

model ProgramKelurahan {
  id          String        @id @default(cuid())
  
  judul       String        @db.VarChar(255)
  deskripsi   String        @db.Text
  
  status      StatusProgram @default(BERJALAN)  // ✅ Langsung aktif
  
  tanggalMulai   DateTime?
  tanggalSelesai DateTime?
  lokasiRt  String? @db.VarChar(3)
  lokasiRw  String? @db.VarChar(3)

  // Kategori (opsional)
  domainIsuId String?
  domainIsu   DomainIsu?     @relation(fields: [domainIsuId], references: [id])

  pic            String?       @db.VarChar(100)

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@map("program_kelurahan")
}